{
	"compilerOptions" : {
		"target" : "ES2022",
		"module" : "ESNext",
		"moduleResolution" : "bundler",
		"lib" : [
			"ES2022",
			"DOM"
		],
		"strict" : true,
		"noUnusedLocals" : true,
		"noUnusedParameters" : true,
		"noFallthroughCasesInSwitch" : true,
		"noUncheckedIndexedAccess" : true,
		"forceConsistentCasingInFileNames" : true,
		"skipLibCheck" : true,
		"isolatedModules" : true,
		"noEmit" : true,
		"types" : [
			"vite/client"
		]
	},
	"include" : [
		"src"
	]
}
